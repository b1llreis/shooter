{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "cmake --build build",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": ["$gcc"]
		},
		{
			"label": "build and run",
			"type": "shell",
			"command": "cmake --build build && ./build/game",
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"problemMatcher": ["$gcc"]
		},
		{
			"label": "clean rebuild",
			"type": "shell",
			"command": "rm -rf build && mkdir build && cd build && cmake .. && make && ./game",
			"problemMatcher": ["$gcc"]
		}
	]
}
